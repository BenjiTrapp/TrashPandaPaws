  ; ── Net labels for key connections ──
  ; (Full wiring defined in design-guide.md — import this schematic
  ;  into KiCad 8 and complete wiring in the GUI)
  ;
  ; KEY NETS:
  ;   +48V_POE    — PoE rail from J14 via F1 to U1
  ;   +5V         — 5V output from U2, feeds Pi via J1 pins 2/4
  ;   +3V3_LOCAL  — 3.3V from U4, feeds U3/U5
  ;   USB3_DP/DM  — USB 3.0 data from U3 to J3
  ;   USB3_SSTX+/- — USB 3.0 SuperSpeed TX
  ;   USB3_SSRX+/- — USB 3.0 SuperSpeed RX
  ;   MDI0..3+/-  — Ethernet MDI pairs from U3 to J2
  ;   GND         — Ground plane
)
